# Copy this to .env and fill in your values
# NEVER commit .env to the repo

METRICOOL_API_KEY=your_metricool_api_key_here

GA4_PROPERTY_ID=your_ga4_numeric_property_id_here

# Local dev only: path to your GA4 service account JSON file
# On Vercel, use GA4_SERVICE_ACCOUNT_JSON instead (paste full JSON string)
GA4_KEY_PATH=./secrets/ga4-service-account.json

# On Vercel, set this to the full JSON contents of your service account file:
# GA4_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
